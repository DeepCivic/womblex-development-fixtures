# Normalise line endings on checkin: avoid CRLF corruption from editors/tools
# on Windows-style filesystems. All text files use LF in the repo.
* text=auto eol=lf

# Binary files — always LFS
*.png filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text

# Large data fixtures — LFS by path
fixtures/isaacus/embeddings/*.json filter=lfs diff=lfs merge=lfs -text
fixtures/isaacus/enrichment/*.json filter=lfs diff=lfs merge=lfs -text
fixtures/isaacus/graph/*.jsonl filter=lfs diff=lfs merge=lfs -text
fixtures/MiniLM_embeddings/*.json filter=lfs diff=lfs merge=lfs -text
fixtures/womblex-collection/_chunks/*.json filter=lfs diff=lfs merge=lfs -text
fixtures/womblex-collection/_extracted/*.json filter=lfs diff=lfs merge=lfs -text
fixtures/womblex-collection/_spreadsheets/*.json filter=lfs diff=lfs merge=lfs -text
